# ── equity-intel-mcp configuration ───────────────────────────────────────────
# Copy this file to `.env` and fill in the values you have.
# Everything except EDGAR_IDENTITY is optional; the core tools run on free data.

# SEC EDGAR requires a contact identity in the request (fair-access policy).
# Any "Name email@example.com" works. Used by equity_insider_activity.
EDGAR_IDENTITY=Your Name your-email@example.com

# Finnhub free API key — required by equity_analyst_consensus.
# Get one free at https://finnhub.io (the /stock/recommendation endpoint is free).
# FINNHUB_API_KEY=your-key-here
